<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Autoware System Designer Deployments</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body class="simple-page">
    <div class="page-container">
        <div class="page-header">
            <h1>Autoware Systems and their Deployments</h1>
            <div class="dark-mode-toggle">
                <label for="dark-mode-switch">Dark Mode</label>
                <div class="toggle-switch" id="dark-mode-switch"></div>
            </div>
        </div>
        <p class="description">Index of available systems and their deployments found in the <code>install/</code> directory.</p>
        <ul class="deployment-list">
            {% for dep in deployments %}
            <li class="deployment-item">
                <div class="deployment-header">
                    <a href="{{ dep.diagram_link }}" class="deployment-name">{{ dep.name }}</a>
                    <div class="deployment-meta">Package: <span class="deployment-package">{{ dep.package }}</span></div>
                </div>
                <div class="item-links">
                    <a class="item-link" href="{{ dep.diagram_link }}">Diagram</a>
                    {% if dep.launch_commands_link %}
                    <a class="item-link" href="{{ dep.launch_commands_link }}">Launch</a>
                    {% endif %}
                </div>
            </li>
            {% endfor %}
        </ul>
    </div>
    <script src="theme.js"></script>
    <script>
        window.initializeTheme();
        document.getElementById('dark-mode-switch').addEventListener('click', function() {
            window.toggleDarkMode();
        });
    </script>
</body>
</html>
